# Billplz API credentials (get from https://www.billplz.com dashboard)
BILLPLZ_API_KEY=your_api_key_here
BILLPLZ_COLLECTION_ID=your_collection_id_here
# Use https://www.billplz-sandbox.com for testing, https://www.billplz.com for production
BILLPLZ_BASE_URL=https://www.billplz-sandbox.com
BILLPLZ_X_SIGNATURE_KEY=your_x_signature_key_here

# Public URL of this site (used for Billplz redirect/callback URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Normal course price in MYR (whole ringgit, will be converted to sen). Members get RM0 automatically.
COURSE_PRICE_MYR=59

# Brevo (formerly Sendinblue) — used for registrant storage (as contacts)
# and transactional confirmation emails. Get the API key from
# Brevo dashboard → Settings → SMTP & API → API Keys.
BREVO_API_KEY=your_brevo_api_key_here
# Must be a sender verified in Brevo (Settings → Senders, Domains & Dedicated IPs)
BREVO_SENDER_EMAIL=no-reply@yourdomain.com
BREVO_SENDER_NAME=Agentic AI for Marketers
# Contact list to add registrants to (Contacts → Lists → find the numeric List ID)
BREVO_LIST_ID=your_list_id_here
# Where admin notifications get sent when a registration is paid
BREVO_ADMIN_EMAIL=admin@yourdomain.com

# Zoom (or Google Meet) join link sent to registrants once payment is confirmed
ZOOM_LINK=https://zoom.us/j/your_meeting_id
